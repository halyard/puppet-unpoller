[prometheus]
  http_listen = "0.0.0.0:9130"
  report_errors = true
  dead_ports = false

[influxdb]
  disable = true

[loki]
  url = "<%= @loki_url %>"
  user       = "<%= @loki_user %>"
  pass       = "<%= @loki_password %>"
  verify_ssl = true
  tenant_id  = ""
  interval   = "2m"
  timeout    = "10s"

[unifi]
  dynamic = false

[unifi.defaults]
  url = "<%= @unifi_url %>"
  user = "<%= @unifi_user %>"
  pass = "<%= @unifi_password %>"
  sites = ["all"]
  save_sites = true
  hash_pii = false
  save_ids = false
  save_events = true
  save_alarms = false
  save_anomalies = false
  save_dpi = false
  save_rogue = false
  verify_ssl = true

